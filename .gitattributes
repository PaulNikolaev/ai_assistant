# Normalize line endings: store as LF in git, checkout as-is on all platforms
* text=auto eol=lf

# Windows batch files must use CRLF
*.bat text eol=crlf
*.cmd text eol=crlf

# Binary files — no line ending conversion
*.png binary
*.jpg binary
*.jpeg binary
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.pyc binary
*.pyd binary
*.so binary
*.dll binary
*.exe binary
