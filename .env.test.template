APP_ENV=testing

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_DB=ai_assistant_test
POSTGRES_USER=ai_assistant
POSTGRES_PASSWORD=test

# Redis
REDIS_HOST=localhost
REDIS_PORT=6380
REDIS_PASSWORD=

# Qdrant
QDRANT_HOST=localhost
QDRANT_PORT=6334

# MinIO
MINIO_ENDPOINT=http://localhost:9002
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=ai-assistant-test

# Security
JWT_SECRET=test-jwt-secret-min-32-chars-replace-this
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# Registration & data retention (optional; config defaults apply)
ALLOW_SELF_REGISTRATION=false
INVITE_TOKEN_EXPIRE_HOURS=72
PASSWORD_RESET_TOKEN_EXPIRE_MINUTES=60
EMAIL_CHANGE_TOKEN_EXPIRE_MINUTES=60
DATA_RETENTION_DAYS=365
AUDIT_RETENTION_DAYS=365

# Internal
MESSENGERS_INTERNAL_SECRET=test-internal-secret

# Superadmin seed
SUPERADMIN_EMAIL=admin@test.com
SUPERADMIN_PASSWORD=testpassword

# Server
ROOT_PATH=
ALLOWED_ORIGINS=http://localhost
