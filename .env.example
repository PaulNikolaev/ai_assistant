# ── App ───────────────────────────────────────────────────────
APP_ENV=development

# ── PostgreSQL ────────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=ai_assistant
POSTGRES_USER=ai_assistant
POSTGRES_PASSWORD=your-postgres-password

# Alternatively, set the full connection string directly (overrides individual fields above):
# DATABASE_URL=postgresql+asyncpg://ai_user:your-postgres-password@postgres:5432/ai_assistant

# ── Redis ─────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# Alternatively:
# REDIS_URL=redis://:your-password@redis:6379

# ── Qdrant ────────────────────────────────────────────────────
QDRANT_HOST=qdrant
QDRANT_PORT=6333

# Alternatively:
# QDRANT_URL=http://qdrant:6333

# ── MinIO ─────────────────────────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=your-minio-password
MINIO_BUCKET=ai-assistant
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=your-minio-password

# ── JWT ───────────────────────────────────────────────────────
# Generate: openssl rand -hex 32
JWT_SECRET=your-jwt-secret-min-32-chars-replace-this
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ── Encryption ────────────────────────────────────────────────
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=your-fernet-key-here

# ── Internal secrets ──────────────────────────────────────────
MESSENGERS_INTERNAL_SECRET=your-internal-secret

# ── CORS ──────────────────────────────────────────────────────
# Comma-separated list of allowed origins (JSON array also supported)
ALLOWED_ORIGINS=http://localhost,http://localhost:80

# ── Auth ──────────────────────────────────────────────────────
SUPERADMIN_EMAIL=admin@example.com
SUPERADMIN_PASSWORD=your-admin-password

# ── LLM providers ─────────────────────────────────────────────
# One of: gigachat | yandex | openrouter | vsegpt
LLM_PROVIDER=openrouter

GIGACHAT_CREDENTIALS=
GIGACHAT_SCOPE=GIGACHAT_API_PERS

YANDEX_API_KEY=
YANDEX_FOLDER_ID=

OPENROUTER_API_KEY=sk-or-...
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

VSEGPT_API_KEY=
VSEGPT_BASE_URL=https://api.vsegpt.ru/v1

# ── Email (dev: MailHog) ──────────────────────────────────────
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@ai-assistant.local

# ── Grafana ───────────────────────────────────────────────────
GF_SECURITY_ADMIN_PASSWORD=admin

# ── Telegram ──────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
